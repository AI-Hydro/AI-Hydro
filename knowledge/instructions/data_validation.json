			"Verify geological reasonableness for region",
			"Cross-reference with geological maps"
		]
	},

	"validation_workflows": {
		"pre_processing_validation": [
			"Validate all input parameters before processing",
			"Check gauge ID exists and has data",
			"Verify date ranges are logical (start < end)",
			"Confirm required data sources are available"
		],

		"during_processing_validation": [
			"Monitor for warnings and errors",
			"Check intermediate results for anomalies",
			"Verify data transformations preserve values",
			"Validate spatial operations maintain geometry"
		],

		"post_processing_validation": [
			"Compare results with expected ranges",
			"Check for missing or null values",
			"Verify units are correctly labeled",
			"Cross-validate related attributes"
		]
	},

	"cross_validation_checks": {
		"water_balance": {
			"equation": "P - ET - Q ≈ ΔS",
			"tolerance": "Within 20% for annual averages",
			"explanation": "Precipitation minus ET and runoff should approximate storage change"
		},

		"energy_balance": {
			"pet_vs_temperature": "PET should correlate with temperature",
			"radiation_consistency": "Solar radiation should match latitude/season",
			"snow_considerations": "Snowmelt timing should match temperature"
		},

		"physical_constraints": {
			"runoff_ratio": "0 < Q/P < 1 (typically 0.2-0.8)",
			"infiltration": "Cannot exceed saturated hydraulic conductivity",
			"evaporation": "Cannot exceed potential ET for extended periods",
			"storage": "Soil moisture cannot exceed porosity"
		}
	},

	"quality_assurance_practices": {
		"documentation": [
			"Record validation criteria used",
			"Document any data quality issues found",
			"Note deviations from expected values",
			"Save validation reports with results"
		],

		"visualization": [
			"Plot time series to identify trends and outliers",
			"Create maps to check spatial patterns",
			"Use box plots for distribution checks",
			"Generate scatter plots for correlation checks"
		],

		"comparison_with_references": [
			"Compare with CAMELS dataset if available",
			"Check against published regional studies",
			"Validate with independent measurements",
			"Cross-reference with neighboring basins"
		]
	},

	"automated_validation": {
		"range_checks": {
			"implementation": "Define min/max for each attribute",
			"action": "Flag values outside acceptable range",
			"example": "if not (200 <= annual_precip <= 4000): flag_warning()"
		},

		"consistency_checks": {
			"implementation": "Check relationships between attributes",
			"action": "Flag inconsistencies for review",
			"example": "if runoff_ratio > 0.9: flag_warning('Unusually high runoff')"
		},

		"completeness_checks": {
			"implementation": "Verify all required attributes present",
			"action": "Report missing attributes",
			"example": "required = ['elev_mean', 'p_mean', 'area_km2']"
		}
	}
