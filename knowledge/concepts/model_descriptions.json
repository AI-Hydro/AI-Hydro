{
	"SWAT": {
		"name": "Soil and Water Assessment Tool",
		"type": "distributed hydrological model",
		"description": "A physically-based, continuous-time watershed model designed to simulate water, sediment, and nutrient transport at the watershed scale.",
		"key_features": [
			"HRU-based spatial discretization",
			"Continuous simulation",
			"Crop growth module",
			"Water quality components"
		],
		"typical_applications": [
			"Agricultural watershed management",
			"Non-point source pollution assessment",
			"Climate change impact studies",
			"Land use change scenarios"
		],
		"input_requirements": [
			"DEM",
			"Land use/land cover",
			"Soil data",
			"Climate data (precipitation, temperature)",
			"Management practices"
		],
		"calibration_parameters": [
			"CN2 (Curve Number)",
			"ALPHA_BF (Baseflow recession constant)",
			"GW_DELAY (Groundwater delay)",
			"ESCO (Soil evaporation compensation factor)"
		],
		"python_tools": [
			"pyswat",
			"swatpy"
		],
		"reference": "Arnold et al. (1998), Neitsch et al. (2011)"
	},
	"HEC-HMS": {
		"name": "Hydrologic Engineering Center - Hydrologic Modeling System",
		"type": "event-based hydrological model",
		"description": "Simulates precipitation-runoff processes of watershed systems, primarily used for flood forecasting and design.",
		"key_features": [
			"Event-based and continuous simulation",
			"Multiple runoff methods (CN, SCS, Green-Ampt)",
			"Channel routing",
			"Reservoir operations"
		],
		"typical_applications": [
			"Flood frequency analysis",
			"Urban drainage design",
			"Dam breach analysis",
			"Real-time forecasting"
		],
		"reference": "USACE (2000)"
	},
	"VIC": {
		"name": "Variable Infiltration Capacity",
		"type": "macroscale hydrological model",
		"description": "A grid-based land surface model that solves full water and energy balances at each grid cell.",
		"key_features": [
			"Sub-grid variability in infiltration",
			"Three soil layers",
			"Full energy balance",
			"Snow accumulation and melt"
		],
		"typical_applications": [
			"Large-scale water resources assessment",
			"Climate change studies",
			"Seasonal forecasting",
			"Data assimilation"
		],
		"spatial_scale": "0.125° to 2° grid cells",
		"reference": "Liang et al. (1994)"
	},
	"SUMMA": {
		"name": "Structure for Unifying Multiple Modeling Alternatives",
		"type": "flexible hydrological modeling framework",
		"description": "A unified approach for hydrological modeling that allows testing of multiple process representations.",
		"key_features": [
			"Multiple physics options",
			"Spatial structure flexibility",
			"NetCDF-based I/O",
			"Modular design"
		],
		"typical_applications": [
			"Process uncertainty quantification",
			"Model comparison studies",
			"Cold region hydrology",
			"Mountain hydrology"
		],
		"reference": "Clark et al. (2015)"
	},
	"SAC-SMA": {
		"name": "Sacramento Soil Moisture Accounting",
		"type": "conceptual hydrological model",
		"description": "A continuous soil moisture accounting model widely used for operational river forecasting.",
		"key_features": [
			"Upper and lower zone storage",
			"Percolation and interflow",
			"16 parameters",
			"Tension and free water storage"
		],
		"typical_applications": [
			"Operational river forecasting",
			"Streamflow prediction",
			"Flood warning systems"
		],
		"usage": "Core model in US National Weather Service River Forecast System",
		"reference": "Burnash et al. (1973)"
	},
	"GR4J": {
		"name": "Génie Rural à 4 paramètres Journalier",
		"type": "lumped conceptual model",
		"description": "A simple, efficient 4-parameter daily rainfall-runoff model.",
		"key_features": [
			"Only 4 parameters",
			"Daily time step",
			"Production and routing stores",
			"Unit hydrograph"
		],
		"typical_applications": [
			"Gauged catchment simulation",
			"Regional modeling",
			"Data-scarce regions"
		],
		"parameters": [
			"X1 (production store capacity)",
			"X2 (groundwater exchange coefficient)",
			"X3 (routing store capacity)",
			"X4 (time base of unit hydrograph)"
		],
		"reference": "Perrin et al. (2003)"
	}
}
