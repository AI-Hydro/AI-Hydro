{
	"p_mean": {
		"description": "Mean daily precipitation",
		"units": "mm/day",
		"group": "climate",
		"source": "Daymet/GridMET",
		"typical_range": "0.5 to 10 mm/day"
	},
	"pet_mean": {
		"description": "Mean daily potential evapotranspiration",
		"units": "mm/day",
		"group": "climate",
		"method": "Priestley-Taylor or Penman-Monteith",
		"typical_range": "1 to 6 mm/day"
	},
	"aridity": {
		"description": "Aridity index (PET/P)",
		"units": "dimensionless",
		"formula": "PET / P",
		"group": "climate",
		"interpretation": "< 1: humid, > 1: water limited"
	},
	"runoff_ratio": {
		"description": "Runoff ratio (Q/P)",
		"units": "dimensionless",
		"formula": "Q / P",
		"group": "hydrology",
		"typical_range": "0.1 to 0.9"
	},
	"baseflow_index": {
		"description": "Baseflow index from digital filter",
		"units": "dimensionless",
