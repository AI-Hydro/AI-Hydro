			"capability_id": "watershed_delineation",
			"name": "Watershed Delineation",
			"description": "Delineate watershed boundaries for USGS gauges using NLDI services",
			"tool": "delineate_watershed",
			"module": "ai_hydro.tools.watershed",
			"status": "production",
			"input_requirements": [
				{
					"parameter": "gauge_id",
					"type": "string",
					"required": true,
					"format": "8-digit USGS gauge ID",
					"example": "01031500"
				}
			],
			"outputs": [
				"watershed boundary geometry",
				"watershed area in km²",
				"gauge metadata (name, location, HUC)",
				"optional shapefile export"
			],
			"use_cases": [
				"Initial step for all watershed analysis",
				"Required before extracting any catchment attributes",
				"Provides spatial boundary for other tools"
			],
			"dependencies": [
				"pygeohydro",
				"pynhd"
			],
			"example_code": "from ai_hydro.tools import delineate_watershed\nwatershed = delineate_watershed('01031500')\nprint(f\"Area: {watershed['area_km2']} km²\")"
		},
