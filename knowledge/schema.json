{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "AI-Hydro Knowledge Base Schema",
	"description": "Validation schema for AI-Hydro knowledge base files",
	"version": "2.0.0",

	"definitions": {
		"concept": {
			"type": "object",
			"properties": {
				"definition": {
					"type": "string",
					"description": "Clear, concise definition of the concept"
				},
				"category": {
					"type": "string",
					"enum": [
						"hydrology",
						"climatology",
						"modeling",
						"geomorphology",
						"ecology",
						"data"
					],
					"description": "Primary category of the concept"
				},
				"synonyms": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Alternative terms for this concept"
				},
				"related_concepts": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Related concepts in the knowledge base"
				},
				"units": {
					"type": "string",
					"description": "SI units if applicable"
				},
				"references": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Citations and references"
				}
			},
			"required": [
				"definition",
				"category"
			]
		},

		"tool": {
			"type": "object",
			"properties": {
				"full_path": {
					"type": "string",
					"pattern": "^[a-z_]+\\.[a-z_]+(\\.[a-z_]+)*$",
					"description": "Full Python import path to the tool"
				},
				"tier": {
					"type": "string",
					"enum": [
						"tier1",
						"tier2",
						"tier3"
					],
					"description": "Tool tier classification"
				},
				"category": {
					"type": "string",
					"enum": [
						"watershed",
						"climate",
						"topography",
						"soil",
						"vegetation",
						"modeling",
						"data",
						"analysis"
					],
					"description": "Tool category"
				},
				"description": {
					"type": "string",
					"description": "What the tool does"
				},
				"purpose": {
					"type": "string",
					"description": "When and why to use this tool"
				},
				"inputs": {
					"type": "object",
					"patternProperties": {
						"^[a-z_]+$": {
							"type": "object",
							"properties": {
								"type": {
									"type": "string"
								},
								"description": {
									"type": "string"
								},
								"required": {
									"type": "boolean"
								},
								"default": {}
							},
							"required": [
								"type",
								"description",
								"required"
							]
						}
					}
				},
				"outputs": {
					"type": "object",
					"properties": {
						"type": {
							"type": "string"
						},
						"description": {
							"type": "string"
						}
					},
					"required": [
						"type",
						"description"
					]
				},
				"usage_example": {
					"type": "string",
					"description": "Working code example"
				},
				"dependencies": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Required Python packages"
				},
				"references": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Citations and documentation links"
				}
			},
			"required": [
				"full_path",
				"tier",
				"category",
				"description",
				"purpose"
			]
		}
	},

	"oneOf": [
		{
			"title": "Concepts File",
			"type": "object",
			"patternProperties": {
				"^[a-z_]+$": {
					"$ref": "#/definitions/concept"
				}
			}
		},
		{
			"title": "Tools File",
			"type": "object",
			"patternProperties": {
				"^[a-z_]+$": {
					"$ref": "#/definitions/tool"
				}
			}
		}
	]
}
